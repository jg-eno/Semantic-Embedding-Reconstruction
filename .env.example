# Hugging Face token with WRITE access (needed to push dataset chunks
# and model checkpoints to the Hub). Get one at:
# https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Weights & Biases API key, used for training run logging.
# Get one at: https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
